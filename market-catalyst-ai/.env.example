# ---------------------------------------------------------------------------
# Market Catalyst AI — environment variables
# Copy this file to .env.local and fill in real values.
# The app runs fully on mock data with NONE of these set — add keys one at a
# time as you wire up each provider. See README.md for a full walkthrough.
# ---------------------------------------------------------------------------

# Supabase (database, auth, watchlists, alerts)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (AI Event Engine + Research Assistant chat)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# News provider (NewsAPI.org, or swap for another provider in src/lib/newsProvider.ts)
NEWSAPI_API_KEY=

# Stock market data — primary provider
POLYGON_API_KEY=
FINNHUB_API_KEY=

# Stock market data — fallback provider used if Polygon/Finnhub fail or are unset
ALPHAVANTAGE_API_KEY=
