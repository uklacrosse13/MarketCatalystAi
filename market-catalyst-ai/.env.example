# ---------------------------------------------------------------------------
# Market Catalyst AI — environment variables
# Copy this file to .env.local and fill in real values.
#
# NONE of these are required for the live News Analysis pipeline (GDELT +
# approved government/public RSS feeds) — it runs entirely on free, keyless
# public sources. See src/config/newsSources.ts to add/remove/disable feeds
# and src/data/marketMappings.ts to edit sector/ticker mappings.
#
# Everything below is optional and unlocks separate, unrelated features.
# ---------------------------------------------------------------------------

# Supabase (database, auth, watchlists persistence) — optional
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — optional, powers ONLY the AI Research Assistant chat page
# (/assistant). Not used anywhere in the news feed, event cards, or
# market-impact analysis, which are entirely rules-based and need no AI
# model. Without this set, the assistant falls back to a labeled canned reply.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Stock market quotes — optional, powers live price lookups via
# src/lib/stockProvider.ts. Without these, company/ticker pages show the
# built-in sample prices.
POLYGON_API_KEY=
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=

# Optional Vercel Cron authentication for proactively warming the news
# cache once a day (see vercel.json and /api/cron/refresh-news). The site
# works correctly without this — the cache also refreshes itself on demand.
CRON_SECRET=
